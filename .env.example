# =========================
# APPLICATION
# =========================
NODE_ENV=production
PORT=3000

# =========================
# DATABASE (POSTGRES ONLY)
# =========================
DATABASE_URL=postgresql://user:password@host:port/database
DB_POOL_SIZE=10

# =========================
# AUTHENTICATION
# =========================
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET
JWT_EXPIRY=24h

# =========================
# CORS (PRODUCTION FRONTEND)
# =========================
CORS_ORIGIN=https://culbridge.cloud

# =========================
# FILE STORAGE
# =========================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10mb

# =========================
# LOGGING
# =========================
LOG_LEVEL=info
LOG_FORMAT=json

# =========================
# API KEYS (OPTIONAL)
# =========================
SENTRY_DSN=
RASFF_API_KEY=
TRACES_API_KEY=

# =========================
# LLM SERVICES (OPTIONAL - LOCAL ONLY)
# =========================
OLLAMA_BASE_URL=http://localhost:11434
LLM_EXTRACT_MODEL=qwen2.5:7b
LLM_CONFLICT_MODEL=deepseek-r1:7b
LLM_EXPLAIN_MODEL=llama3.1:8b

# =========================
# ENTERPRISE INTEGRATIONS (OPTIONAL)
# =========================
HYPERLEDGER_URL=http://localhost:7051
HYPERLEDGER_CHANNEL=culbridge-channel
HYPERLEDGER_CHAINCODE=culbridgecc

ODOO_URL=http://localhost:8069
ODOO_DATABASE=culbridge
ODOO_USERNAME=admin
ODOO_PASSWORD=your-odoo-password

OPENLMIS_URL=http://localhost:8080

# =========================
# RATE LIMITING
# =========================
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100