# Culbridge Environment Configuration
# Copy this file to .env and update values

# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=./culbridge.db
DB_POOL_SIZE=10

# Authentication
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY=24h

# API Keys (replace with real values)
SENTRY_DSN=
RASFF_API_KEY=
TRACES_API_KEY=

# LLM Services
OLLAMA_BASE_URL=http://localhost:11434
LLM_EXTRACT_MODEL=qwen2.5:7b
LLM_CONFLICT_MODEL=deepseek-r1:7b
LLM_EXPLAIN_MODEL=llama3.1:8b

# External Services
HYPERLEDGER_URL=http://localhost:7051
HYPERLEDGER_CHANNEL=culbridge-channel
HYPERLEDGER_CHAINCODE=culbridgecc

ODOO_URL=http://localhost:8069
ODOO_DATABASE=culbridge
ODOO_USERNAME=admin
ODOO_PASSWORD=your-odoo-password

OPENLMIS_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3000

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10mb
