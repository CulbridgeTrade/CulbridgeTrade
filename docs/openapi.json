{
  "openapi": "3.0.3",
  "info": {
    "title": "Culbridge Compliance API",
    "description": "Deterministic compliance engine for agricultural export compliance\n\n## Key Features\n- Deterministic rule evaluation (no probabilistic outcomes)\n- Full audit trail for regulatory compliance\n- Multi-corridor support (EU, USA, etc.)\n- Lab and document verification\n- HS Code validation\n\n## Error Handling\nAll endpoints return standardized error responses. See `EngineError` schema.",
    "version": "1.0.0",
    "contact": {
      "name": "Culbridge API Support",
      "email": "support@culbridge.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    },
    {
      "url": "https://api.culbridge.com/v1",
      "description": "Production server"
    }
  ],
  "tags": [
    { "name": "Health", "description": "System health and readiness" },
    { "name": "Shipments", "description": "Shipment management and evaluation" },
    { "name": "Labs", "description": "Lab registry and verification" },
    { "name": "Documents", "description": "Document upload and verification" },
    { "name": "Compliance", "description": "Compliance rules and evaluations" },
    { "name": "Audit", "description": "Audit logs and traceability" },
    { "name": "Auth", "description": "Authentication and authorization" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns system health status and readiness",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthStatus" },
                "example": {
                  "status": "ok",
                  "timestamp": 1700000000000,
                  "version": "1.0.0",
                  "database": "connected"
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "tags": ["Health"],
        "summary": "Readiness check",
        "description": "Returns if system is ready to accept traffic",
        "responses": {
          "200": {
            "description": "System ready",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReadinessStatus" }
              }
            }
          }
        }
      }
    },
    "/shipments": {
      "get": {
        "tags": ["Shipments"],
        "summary": "List all shipments",
        "description": "Returns paginated list of shipments. Filters by status, product, corridor.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by shipment status",
            "schema": { "type": "string", "enum": ["DRAFT", "PENDING_VALIDATION", "VALIDATING", "READY_TO_SUBMIT", "SUBMITTED", "UNDER_REVIEW", "APPROVED", "REJECTED", "SIGNED"] }
          },
          {
            "name": "product",
            "in": "query",
            "description": "Filter by product category",
            "schema": { "type": "string", "enum": ["cocoa", "sesame", "cashew", "ginger", "groundnuts", "seeds"] }
          },
          {
            "name": "corridor",
            "in": "query",
            "description": "Filter by destination corridor",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of shipments",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ShipmentListResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Shipments"],
        "summary": "Create new shipment",
        "description": "Creates a new shipment in DRAFT status. Use /shipments/{id}/evaluate for compliance check.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ShipmentInput" },
              "example": {
                "product": "cocoa beans",
                "category": "cocoa",
                "hs_code": "1801.00.10",
                "origin_country": "NG",
                "destination_country": "DE",
                "batch_number": "CB-2026-001",
                "quantity_kg": 25000,
                "exporter_id": "EXP-001"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Shipment created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Shipment" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      }
    },
    "/shipments/{id}": {
      "get": {
        "tags": ["Shipments"],
        "summary": "Get shipment by ID",
        "description": "Returns full shipment details including all module outputs",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Shipment ID", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Shipment details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ShipmentDetail" }
              }
            }
          },
          "404": {
            "description": "Shipment not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Shipments"],
        "summary": "Update shipment",
        "description": "Update shipment fields. Only allowed for DRAFT status.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ShipmentUpdateInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shipment updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Shipment" }
              }
            }
          },
          "400": {
            "description": "Update not allowed (not DRAFT)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Shipments"],
        "summary": "Delete shipment",
        "description": "Delete shipment. Only allowed for DRAFT status.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Shipment deleted" },
          "400": {
            "description": "Cannot delete (not DRAFT)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      }
    },
    "/shipments/{id}/evaluate": {
      "post": {
        "tags": ["Compliance"],
        "summary": "Evaluate shipment compliance",
        "description": "Runs deterministic compliance evaluation. Returns BLOCKERS, WARNINGS, and audit log.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Evaluation result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EvaluationResult" },
                "example": {
                  "shipment_id": "CB-001",
                  "status": "SAFE",
                  "score": 95,
                  "blockers": [],
                  "warnings": [
                    {
                      "code": "LOW_CONFIDENCE_HS_CODE",
                      "message": "HS Code 1801.00 has 65% confidence",
                      "severity": "WARNING"
                    }
                  ],
                  "audit_log": [
                    {
                      "rule_id": "EU_COCOA_AFLATOXIN_001_v2",
                      "input": { "value": 3.5, "unit": "μg/kg" },
                      "result": "PASS",
                      "timestamp": "2026-03-28T10:23:00Z"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/shipments/{id}/submit": {
      "post": {
        "tags": ["Shipments"],
        "summary": "Submit shipment for processing",
        "description": "Submits shipment to NSW ESB. Requires READY_TO_SUBMIT status.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Submission result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SubmissionResult" }
              }
            }
          },
          "400": {
            "description": "Not ready for submission",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      }
    },
    "/shipments/{id}/audit": {
      "get": {
        "tags": ["Audit"],
        "summary": "Get audit log for shipment",
        "description": "Returns immutable audit log with all rule evaluations and state transitions",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "module", "in": "query", "description": "Filter by module", "schema": { "type": "string" } },
          { "name": "from_date", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "to_date", "in": "query", "schema": { "type": "string", "format": "date-time" } }
        ],
        "responses": {
          "200": {
            "description": "Audit log entries",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuditLogResponse" }
              }
            }
          }
        }
      }
    },
    "/shipments/{id}/fees": {
      "get": {
        "tags": ["Shipments"],
        "summary": "Get fee calculation",
        "description": "Returns calculated export fees with breakdown by agency",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Fee calculation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FeeCalculation" }
              }
            }
          }
        }
      }
    },
    "/labs": {
      "get": {
        "tags": ["Labs"],
        "summary": "List verified labs",
        "description": "Returns list of verified labs. Filter by tier, country, accreditation.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "tier",
            "in": "query",
            "description": "Filter by trust tier (1=highest)",
            "schema": { "type": "integer", "enum": [1, 2, 3] }
          },
          {
            "name": "country",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "accreditation",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of labs",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LabListResponse" }
              }
            }
          }
        }
      }
    },
    "/labs/{id}": {
      "get": {
        "tags": ["Labs"],
        "summary": "Get lab details",
        "description": "Returns full lab details including accreditation scope and verification status",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Lab details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LabDetail" }
              }
            }
          }
        }
      }
    },
    "/documents/upload": {
      "post": {
        "tags": ["Documents"],
        "summary": "Upload document",
        "description": "Upload document (PDF, JPG, PNG, DOCX). Max 20MB.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file", "shipment_id", "document_type"],
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "shipment_id": { "type": "string" },
                  "document_type": { "type": "string", "enum": ["COO", "phytosanitary", "health_cert", "lab_report", "packing_list", "invoice"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document uploaded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DocumentUploadResult" }
              }
            }
          },
          "413": {
            "description": "File too large",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      }
    },
    "/documents/{id}": {
      "get": {
        "tags": ["Documents"],
        "summary": "Get document metadata",
        "description": "Returns document metadata and verification status",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Document metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Document" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Documents"],
        "summary": "Delete document",
        "description": "Delete document. Only allowed for DRAFT shipments.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Document deleted" }
        }
      }
    },
    "/rules": {
      "get": {
        "tags": ["Compliance"],
        "summary": "List compliance rules",
        "description": "Returns all active compliance rules with versions. Filter by product, corridor, hazard.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "product", "in": "query", "schema": { "type": "string" } },
          { "name": "corridor", "in": "query", "schema": { "type": "string" } },
          { "name": "hazard", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of rules",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RuleListResponse" }
              }
            }
          }
        }
      }
    },
    "/rules/{id}": {
      "get": {
        "tags": ["Compliance"],
        "summary": "Get rule details",
        "description": "Returns full rule definition including conditions, effects, and examples",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Rule details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RuleDetail" }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login and get JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 }
                }
              },
              "example": {
                "email": "exporter@company.com",
                "password": "securepassword"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LoginResponse" }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": {
                  "refresh_token": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          }
        }
      }
    },
    "/admin/analytics": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get system analytics",
        "description": "Returns system metrics, queue depth, error rates. Admin only.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Analytics data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AnalyticsResponse" }
              }
            }
          },
          "403": {
            "description": "Forbidden - Admin only",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EngineError" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "HealthStatus": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["ok", "degraded", "down"] },
          "timestamp": { "type": "integer" },
          "version": { "type": "string" },
          "database": { "type": "string", "enum": ["connected", "disconnected"] },
          "services": {
            "type": "object",
            "properties": {
              "ruleEngine": { "type": "string" },
              "auditLogger": { "type": "string" },
              "documentVault": { "type": "string" }
            }
          }
        }
      },
      "ReadinessStatus": {
        "type": "object",
        "properties": {
          "ready": { "type": "boolean" },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "status": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      },
      "Shipment": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Unique shipment identifier (e.g., CB-001)" },
          "status": { 
            "type": "string", 
            "enum": ["DRAFT", "PENDING_VALIDATION", "VALIDATING", "READY_TO_SUBMIT", "SUBMITTED", "UNDER_REVIEW", "APPROVED", "REJECTED", "SIGNED"] 
          },
          "product": { "type": "string", "description": "Product name" },
          "category": { "type": "string", "enum": ["cocoa", "sesame", "cashew", "ginger", "groundnuts", "seeds"] },
          "hs_code": { "type": "string", "description": "Harmonized System code (6-10 digits)" },
          "origin_country": { "type": "string", "description": "ISO 2-letter country code" },
          "destination_country": { "type": "string", "description": "Destination corridor/country" },
          "batch_number": { "type": "string" },
          "quantity_kg": { "type": "number" },
          "exporter_id": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ShipmentDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/Shipment" },
          {
            "type": "object",
            "properties": {
              "hs_code_validation": { "$ref": "#/components/schemas/HSCodeValidation" },
              "documents": { "type": "array", "items": { "$ref": "#/components/schemas/Document" } },
              "compliance": { "$ref": "#/components/schemas/ComplianceStatus" },
              "fees": { "$ref": "#/components/schemas/FeeCalculation" },
              "signature": { "$ref": "#/components/schemas/SignatureStatus" },
              "audit_log": { "type": "array", "items": { "$ref": "#/components/schemas/AuditLogEntry" } }
            }
          }
        ]
      },
      "ShipmentInput": {
        "type": "object",
        "required": ["product", "category", "hs_code", "origin_country", "destination_country", "exporter_id"],
        "properties": {
          "product": { "type": "string", "description": "Product name" },
          "category": { "type": "string", "enum": ["cocoa", "sesame", "cashew", "ginger", "groundnuts", "seeds"] },
          "hs_code": { "type": "string", "pattern": "^[0-9]{6,10}$", "description": "6-10 digit HS code" },
          "origin_country": { "type": "string", "minLength": 2, "maxLength": 2 },
          "destination_country": { "type": "string", "description": "Destination country code" },
          "batch_number": { "type": "string" },
          "quantity_kg": { "type": "number", "minimum": 0 },
          "exporter_id": { "type": "string" },
          "agent_id": { "type": "string", "description": "Optional agent" }
        }
      },
      "ShipmentUpdateInput": {
        "type": "object",
        "properties": {
          "product": { "type": "string" },
          "hs_code": { "type": "string" },
          "destination_country": { "type": "string" },
          "quantity_kg": { "type": "number" }
        }
      },
      "ShipmentListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Shipment" } },
          "pagination": { "$ref": "#/components/schemas/Pagination" }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "limit": { "type": "integer" },
          "total": { "type": "integer" },
          "pages": { "type": "integer" }
        }
      },
      "EvaluationResult": {
        "type": "object",
        "properties": {
          "shipment_id": { "type": "string" },
          "status": { "type": "string", "enum": ["BLOCKED", "HIGH_RISK", "SAFE"] },
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "blockers": { "type": "array", "items": { "$ref": "#/components/schemas/EngineError" }, "description": "Critical errors that block submission" },
          "warnings": { "type": "array", "items": { "$ref": "#/components/schemas/EngineError" }, "description": "Non-critical issues" },
          "audit_log": { "type": "array", "items": { "$ref": "#/components/schemas/AuditLogEntry" } },
          "threshold_adjustments": { "type": "array", "items": { "type": "object" }, "description": "Dynamic threshold changes applied" },
          "rasff_alerts": { "type": "array", "items": { "type": "object" }, "description": "Matched RASFF alerts" }
        }
      },
      "ComplianceStatus": {
        "type": "object",
        "properties": {
          "eudr_compliant": { "type": "boolean" },
          "rasff_flags": { "type": "array", "items": { "type": "object" } },
          "lab_results": { "type": "array", "items": { "$ref": "#/components/schemas/LabResult" } },
          "violations": { "type": "array", "items": { "type": "object" } }
        }
      },
      "HSCodeValidation": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "alternatives": { "type": "array", "items": { "type": "string" } },
          "validated": { "type": "boolean" }
        }
      },
      "RuleListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/RuleSummary" } }
        }
      },
      "RuleSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" },
          "product": { "type": "string" },
          "corridor": { "type": "string" },
          "hazard": { "type": "string" },
          "status": { "type": "string", "enum": ["ACTIVE", "DEPRECATED", "DRAFT"] },
          "effective_date": { "type": "string", "format": "date" }
        }
      },
      "RuleDetail": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Rule ID (e.g., EU_SESAME_EO_001_v3)" },
          "version": { "type": "string" },
          "scope": {
            "type": "object",
            "properties": {
              "product": { "type": "array", "items": { "type": "string" } },
              "corridor": { "type": "array", "items": { "type": "string" } },
              "hazard": { "type": "array", "items": { "type": "string" } }
            }
          },
          "condition": { "type": "string", "description": "Technical condition (e.g., ethylene_oxide <= 0.1)" },
          "effect": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKER", "WARNING"] },
          "threshold": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" } } },
          "examples": { "type": "array", "items": { "type": "object" } },
          "audit_reference": { "type": "string" }
        }
      },
      "AuditLogResponse": {
        "type": "object",
        "properties": {
          "shipment_id": { "type": "string" },
          "entries": { "type": "array", "items": { "$ref": "#/components/schemas/AuditLogEntry" } },
          "total": { "type": "integer" }
        }
      },
      "AuditLogEntry": {
        "type": "object",
        "description": "Immutable audit log entry for regulatory compliance",
        "properties": {
          "event_id": { "type": "string", "description": "Unique event identifier" },
          "rule_id": { "type": "string", "description": "Rule that triggered this event" },
          "input": {
            "type": "object",
            "properties": {
              "value": { "type": "number" },
              "unit": { "type": "string" },
              "lab_id": { "type": "string" },
              "document_id": { "type": "string" }
            }
          },
          "result": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKER", "WARNING"] },
          "timestamp": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp" },
          "actor": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "role": { "type": "string" }
            }
          },
          "context": { "type": "object", "description": "Additional context (shipment_id, version, etc.)" },
          "hash": { "type": "string", "description": "SHA-256 hash for integrity verification" }
        }
      },
      "FeeCalculation": {
        "type": "object",
        "properties": {
          "shipment_id": { "type": "string" },
          "total": { "type": "number", "description": "Total fee in Naira" },
          "breakdown": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "certificate_id": { "type": "string" },
                "agency_name": { "type": "string" },
                "fee_naira": { "type": "number" },
                "processing_days": { "type": "integer" }
              }
            }
          },
          "estimated_processing_days": { "type": "object", "properties": { "min": { "type": "integer" }, "max": { "type": "integer" } } },
          "critical_path_days": { "type": "integer" }
        }
      },
      "SubmissionResult": {
        "type": "object",
        "properties": {
          "shipment_id": { "type": "string" },
          "sgd_number": { "type": "string", "description": "NSW-generated SGD number" },
          "submission_status": { "type": "string" },
          "submitted_at": { "type": "string", "format": "date-time" }
        }
      },
      "Lab": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "country": { "type": "string" },
          "accreditation": { "type": "string" },
          "verified": { "type": "boolean" }
        }
      },
      "LabDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/Lab" },
          {
            "type": "object",
            "properties": {
              "tier": { "type": "integer", "enum": [1, 2, 3], "description": "Trust tier (1=highest)" },
              "accreditation_scopes": { "type": "array", "items": { "type": "string" } },
              "verification_date": { "type": "string", "format": "date" },
              "last_audit": { "type": "string", "format": "date" }
            }
          }
        ]
      },
      "LabListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Lab" } },
          "total": { "type": "integer" }
        }
      },
      "LabResult": {
        "type": "object",
        "properties": {
          "lab_id": { "type": "string" },
          "test_type": { "type": "string" },
          "result": { "type": "number" },
          "unit": { "type": "string" },
          "limit": { "type": "number" },
          "status": { "type": "string", "enum": ["PASS", "FAIL"] },
          "test_date": { "type": "string", "format": "date" }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "shipment_id": { "type": "string" },
          "document_type": { "type": "string", "enum": ["COO", "phytosanitary", "health_cert", "lab_report", "packing_list", "invoice"] },
          "file_name": { "type": "string" },
          "file_hash": { "type": "string", "description": "SHA-256 hash" },
          "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
          "uploaded_at": { "type": "string", "format": "date-time" }
        }
      },
      "DocumentUploadResult": {
        "type": "object",
        "properties": {
          "document_id": { "type": "string" },
          "storage_path": { "type": "string" },
          "hash": { "type": "string" },
          "uploaded_at": { "type": "string", "format": "date-time" }
        }
      },
      "SignatureStatus": {
        "type": "object",
        "properties": {
          "signature_id": { "type": "string" },
          "signature_type": { "type": "string" },
          "signer_identity": { "type": "string" },
          "signing_time": { "type": "string", "format": "date-time" },
          "verified": { "type": "boolean" }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "JWT access token" },
          "refresh_token": { "type": "string" },
          "expires_in": { "type": "integer", "description": "Seconds" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "expires_in": { "type": "integer" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["exporter", "compliance", "admin", "founder"] },
          "name": { "type": "string" },
          "entity_id": { "type": "string", "description": "Associated exporter/company ID" }
        }
      },
      "AnalyticsResponse": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "metrics": {
            "type": "object",
            "properties": {
              "total_shipments": { "type": "integer" },
              "pending_review": { "type": "integer" },
              "approved_today": { "type": "integer" },
              "rejected_today": { "type": "integer" },
              "queue_depth": { "type": "integer" },
              "worker_load": { "type": "number" },
              "api_success_rate": { "type": "number" },
              "error_rate": { "type": "number" }
            }
          },
          "external_services": {
            "type": "object",
            "properties": {
              "nsw": { "type": "string", "enum": ["healthy", "degraded", "down"] },
              "remita": { "type": "string", "enum": ["healthy", "degraded", "down"] },
              "nimc": { "type": "string", "enum": ["healthy", "degraded", "down"] }
            }
          }
        }
      },
      "EngineError": {
        "type": "object",
        "description": "Standardized error object for all engine errors",
        "properties": {
          "name": { "type": "string", "description": "Error class name" },
          "severity": { "type": "string", "enum": ["BLOCKER", "WARNING", "INFO"], "description": "Error severity level" },
          "code": { "type": "string", "description": "Unique error code (e.g., API_TIMEOUT, MISSING_DOCUMENT)" },
          "message": { "type": "string", "description": "Human-readable message" },
          "context": { "type": "object", "description": "Additional context (shipmentId, labId, etc.)" },
          "timestamp": { "type": "string", "format": "date-time" },
          "stack": { "type": "string", "description": "Error stack trace (dev only)" }
        },
        "required": ["severity", "code", "message", "timestamp"]
      },
      "ShipmentInput_old": {
        "type": "object",
        "required": ["product_name", "hs_code", "origin_country", "destination_country"],
        "properties": {
          "product_name": { "type": "string" },
          "hs_code": { "type": "string" },
          "origin_country": { "type": "string" },
          "destination_country": { "type": "string" },
          "batch_id": { "type": "string" }
        }
      },
      "DecisionInput": {
        "type": "object",
        "required": ["shipment_id", "lab_aflatoxin_total"],
        "properties": {
          "shipment_id": { "type": "string" },
          "lab_aflatoxin_total": { "type": "number" },
          "lab_pesticide_count": { "type": "number" },
          "lab_salmonella_present": { "type": "boolean" },
          "exporter_risk_score": { "type": "number" },
          "historical_rejections": { "type": "number" },
          "destination_port": { "type": "string" },
          "shipment_value": { "type": "number" }
        }
      },
      "DecisionOutput": {
        "type": "object",
        "properties": {
          "decision": { "type": "string", "enum": ["CLEAR_TO_SHIP", "DO_NOT_SHIP", "REVIEW_REQUIRED", "INSUFFICIENT_DATA"] },
          "risk_score": { "type": "number" },
          "confidence": { "type": "number" },
          "expected_loss_usd": { "type": "number" },
          "cheapest_fix": { "type": "object" }
        }
      }
    }
  }
}