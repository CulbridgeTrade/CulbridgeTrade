# Culbridge Production Environment Configuration
# Copy this file to .env and update values

# ============================================
# CRITICAL PRODUCTION SETTINGS
# These must be correctly configured for auth to work
# ============================================

# Application
NODE_ENV=production
PORT=3000

# Database — PostgreSQL REQUIRED for production
# SQLite (./culbridge.db) is NOT suitable for production because Render's
# filesystem is ephemeral. Data will be lost on every redeploy/restart.
# Use Render managed PostgreSQL or another hosted Postgres provider.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:port/database
DB_POOL_SIZE=10

# Authentication
# JWT_SECRET must be a strong random string (minimum 64 bytes recommended).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit the real secret to GitHub or share it outside the team.
JWT_SECRET=change-this-to-a-secure-random-string-minimum-64-bytes
JWT_EXPIRY=24h

# Frontend API URL
# Must point to the deployed backend, NOT localhost.
# This is a NEXT_PUBLIC_ variable — it is baked in at build time in Next.js.
# You must redeploy after changing this value for it to take effect.
NEXT_PUBLIC_API_URL=https://culbridgetrade.onrender.com

# API Keys (replace with real values)
SENTRY_DSN=
RASFF_API_KEY=
TRACES_API_KEY=

# External Services
HYPERLEDGER_URL=http://localhost:7051
ODOO_URL=http://localhost:8069
OPENLMIS_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=https://culbridgetrade.onrender.com
