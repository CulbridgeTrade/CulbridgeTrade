  "productOntology": {
    "description": "Required lab tests per commodity",
    "products": {
      "sesame": {
        "requiredTests": ["ethylene_oxide", "aflatoxin", "salmonella"],
        "notes": "EU requires all three - ethylene oxide banned since 2022"
      },
      "cocoa": {
        "requiredTests": ["aflatoxin", "cadmium"],
        "notes": "Cadmium limit strict for EU cocoa products"
      },
      "cashew": {
        "requiredTests": ["aflatoxin", "lead"],
        "notes": "Lead testing important for cashews"
      },
      "ginger": {
        "requiredTests": ["ethylene_oxide", "aflatoxin"],
        "notes": "Ethylene oxide concern for ginger"
      },
      "fish": {
        "requiredTests": ["mercury", "histamine"],
        "notes": "Scombroid fish species require histamine test"
      },
      "coffee": {
        "requiredTests": ["aflatoxin", "ochratoxin_a"],
        "notes": "Ochratoxin A concern for coffee"
      },
      "spices": {
        "requiredTests": ["aflatoxin", "ethylene_oxide", "salmonella"],
        "notes": "Multiple requirements for spice exports"
      },
      "groundnuts": {
        "requiredTests": ["aflatoxin"],
        "notes": "Peanuts = highest aflatoxin risk"
      },
      "seeds": {
        "requiredTests": ["aflatoxin", "ethylene_oxide"],
        "notes": "Similar to sesame requirements"
      }
    }
  },

  "mrlThresholds": {
    "description": "Maximum Residue Limits for EU",
    "jurisdiction": "EU",
    "thresholds": [
      { "substance": "ethylene_oxide", "limit": 0.1, "unit": "mg/kg" },
      { "substance": "aflatoxin_b1", "limit": 2.0, "unit": "μg/kg" },
      { "substance": "aflatoxin_total", "limit": 4.0, "unit": "μg/kg" },
      { "substance": "chlorpyrifos", "limit": 0.01, "unit": "mg/kg" },
      { "substance": "dichlorvos", "limit": 0.01, "unit": "mg/kg" },
      { "substance": "cadmium", "limit": 0.5, "unit": "mg/kg", "appliesTo": "cocoa" },
      { "substance": "lead", "limit": 0.1, "unit": "mg/kg" },
      { "substance": "mercury", "limit": 1.0, "unit": "mg/kg", "appliesTo": "fish" },
      { "substance": "histamine", "limit": 100, "unit": "mg/kg", "appliesTo": "fish" },
      { "substance": "ochratoxin_a", "limit": 3.0, "unit": "μg/kg", "appliesTo": "coffee" },
      { "substance": "salmonella", "limit": 0, "unit": "absent/25g", "appliesTo": "sesame" }
    ]
  },

  "ruleEngine": {
    "description": "Lab verification + MRL/contaminant checks",
    "rules": [
      {
        "id": "LAB_VERIFIED_ACTIVE",
        "name": "Lab must be verified and active",
        "scope": { "product": "any", "corridor": "any" },
        "condition": {
          "field": "labResults.$KEY.labId.status",
          "operator": "==",
          "value": "ACTIVE"
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Lab is not ACTIVE"
        },
        "source": { "regulation": "Culbridge Core", "reference": "LAB_VERIFY_001" }
      },
      {
        "id": "LAB_VERIFIED_TRUE",
        "name": "Lab must be system-verified",
        "scope": { "product": "any", "corridor": "any" },
        "condition": {
          "field": "labResults.$KEY.labId.verified",
          "operator": "==",
          "value": true
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Result from unverified lab"
        },
        "source": { "regulation": "Culbridge Core", "reference": "LAB_VERIFY_002" }
      },
      {
        "id": "REQUIRED_TEST_EXISTS",
        "name": "Required lab test must exist",
        "scope": { "product": "$PRODUCT", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.$REQUIRED_TEST",
          "operator": "EXISTS",
          "value": true
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Mandatory lab test missing: $REQUIRED_TEST"
        },
        "source": { "regulation": "EU Import Requirements", "reference": "LAB_REQ_001" }
      },
      {
        "id": "MRL_ETHYLENE_OXIDE",
        "name": "Ethylene oxide limit",
        "scope": { "product": "sesame", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.ethylene_oxide.value",
          "operator": ">",
          "value": 0.1
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Ethylene oxide exceeds EU MRL of 0.1 mg/kg"
        },
        "source": { "regulation": "EU 2022/1430", "reference": "MRL_EO_001" }
      },
      {
        "id": "MRL_AFLATOXIN_B1",
        "name": "Aflatoxin B1 limit",
        "scope": { "product": "sesame", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.aflatoxin_b1.value",
          "operator": ">",
          "value": 2.0
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Aflatoxin B1 exceeds EU MRL of 2.0 μg/kg"
        },
        "source": { "regulation": "EU 2023/915", "reference": "MRL_AFLA_001" }
      },
      {
        "id": "MRL_AFLATOXIN_TOTAL",
        "name": "Total aflatoxin limit",
        "scope": { "product": "sesame", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.aflatoxin_total.value",
          "operator": ">",
          "value": 4.0
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Total aflatoxins exceed EU MRL of 4.0 μg/kg"
        },
        "source": { "regulation": "EU 2023/915", "reference": "MRL_AFLA_002" }
      },
      {
        "id": "MRL_CADMIUM_COCOA",
        "name": "Cadmium limit for cocoa",
        "scope": { "product": "cocoa", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.cadmium.value",
          "operator": ">",
          "value": 0.5
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Cadmium exceeds EU limit of 0.5 mg/kg for cocoa"
        },
        "source": { "regulation": "EU 2023/466", "reference": "MRL_CD_001" }
      },
      {
        "id": "MRL_LEAD_CASHEW",
        "name": "Lead limit for cashew",
        "scope": { "product": "cashew", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.lead.value",
          "operator": ">",
          "value": 0.1
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Lead exceeds EU limit of 0.1 mg/kg"
        },
        "source": { "regulation": "EU 2023/915", "reference": "MRL_PB_001" }
      },
      {
        "id": "SALMONELLA_ABSENT",
        "name": "Salmonella must be absent",
        "scope": { "product": "sesame", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.salmonella.value",
          "operator": ">",
          "value": 0
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Salmonella must be absent (0) for sesame exports"
        },
        "source": { "regulation": "EU Regulation 2073/2005", "reference": "MICRO_001" }
      },
      {
        "id": "MRL_MERCURY_FISH",
        "name": "Mercury limit for fish",
        "scope": { "product": "fish", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.mercury.value",
          "operator": ">",
          "value": 1.0
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Mercury exceeds EU limit of 1.0 mg/kg"
        },
        "source": { "regulation": "EU 2023/915", "reference": "MRL_HG_001" }
      },
      {
        "id": "MRL_HISTAMINE_FISH",
        "name": "Histamine limit for fish",
        "scope": { "product": "fish", "corridor": "NG→EU" },
        "condition": {
          "field": "labResults.histamine.value",
          "operator": ">",
          "value": 100
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Histamine exceeds EU limit of 100 mg/kg"
        },
        "source": { "regulation": "EU 2023/915", "reference": "MRL_HIST_001" }
      },
      {
        "id": "LAB_REPORT_HASH",
        "name": "Lab result must have report hash",
        "scope": { "product": "any", "corridor": "any" },
        "condition": {
          "field": "labResults.$KEY.reportHash",
          "operator": "EXISTS",
          "value": true
        },
        "effect": {
          "type": "BLOCKER",
          "message": "Lab result missing report hash for audit trail"
        },
        "source": { "regulation": "Culbridge Core", "reference": "AUDIT_001" }
      }
    ]
  },

