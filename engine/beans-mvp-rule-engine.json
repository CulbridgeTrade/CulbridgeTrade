{
  "product": "brown_white_beans",
  "corridor": ["NL", "DE"],
  "extraction_mapping": {
    "aflatoxin_b1": {"source": "coa_lab_report", "type": "number", "unit": "µg/kg", "hard_blocker": true, "limit": 2},
    "aflatoxin_total": {"source": "coa_lab_report", "type": "number", "unit": "µg/kg", "hard_blocker": true, "limit": 4},
    "pesticides": {"source": "coa_lab_report", "type": "array", "critical_penalty": true, "mrl_check": true},
    "Salmonella_present": {"source": "microbiology_report", "type": "boolean", "hard_blocker": true},
    "moisture_percent": {"source": "lab_report", "type": "number", "unit": "%", "hard_blocker": true, "limit": 14},
    "botanical_name": {"source": "phytosanitary_certificate", "type": "string", "expected": "Phaseolus vulgaris", "hard_blocker": true},
    "traceability_chain": {"source": "shipping_docs", "type": "array", "hard_blocker": true},
    "certificate_of_origin": {"source": "shipping_docs", "type": "boolean", "required": true, "hard_blocker": true},
    "phytosanitary_certificate": {"source": "shipping_docs", "type": "boolean", "required": true, "hard_blocker": true},
    "lab_batch_number": {"source": "lab_report", "type": "string"},
    "shipment_batch_number": {"source": "shipping_manifest", "type": "string"}
  },
  "deterministic_flow": [
    "validate_extraction",
    "check_certificates",
    "batch_linkage",
    "mycotoxins_hard_block",
    "salmonella_hard_block",
    "moisture_hard_block",
    "botanical_verification",
    "traceability_check",
    "pesticide_mrl_check",
    "log_immutable_snapshot"
  ],
  "logic": [
    "if !certificate_of_origin OR !phytosanitary_certificate → BLOCK 'missing certs'",
    "if lab_batch_number != shipment_batch_number → BLOCK 'batch mismatch'",
    "if aflatoxin_total > 4 OR aflatoxin_b1 > 2 → BLOCK 'mycotoxins exceed'",
    "if Salmonella_present → BLOCK 'pathogen detected'",
    "if moisture_percent > 14 → BLOCK 'storage violation'",
    "if botanical_name != 'Phaseolus vulgaris' → BLOCK 'species mismatch'",
    "if !traceability_chain.length → BLOCK 'traceability failure'",
    "for each pesticide: if value > MRL → CRITICAL_PENALTY",
    "log all evaluations w/ snapshot"
  ]
}

