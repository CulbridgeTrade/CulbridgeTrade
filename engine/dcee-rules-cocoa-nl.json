      "id": "PHYTO_CERT_COCOA_NL",
      "type": "document",
      "applies_if": {
        "product": ["cocoa_beans"],
        "destination_country": ["NL"],
        "entry_port": ["rotterdam"],
        "use_case": "food_import"
      },
      "priority": 1,
      "payload": {
        "id": "PHYTO_CERT",
        "name": "Phytosanitary Certificate",
        "issuer": "NAQS Nigeria",
        "required": true,
        "validity_days": 14,
        "fields_required": ["product_name", "batch_id", "origin", "pest_status"],
        "blocking": true
      },
      "source": "EU 2019/2072",
      "confidence": "high",
      "last_verified": "2025-01-15",
      "versioning": {
        "current_version": "v1.0",
        "effective_from": "2025-01-01",
